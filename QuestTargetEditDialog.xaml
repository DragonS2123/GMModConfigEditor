<Window x:Class="GMCraftTableEditor.QuestTargetEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.QTD.Title}"
        Height="560" Width="700"
        MinHeight="480" MinWidth="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource TextBrush}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Тип цели ───────────────────────────────────────────────────── -->
        <GroupBox Header="{DynamicResource S.QTD.TypeQuest}" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="TypeCombo"
                          SelectionChanged="TypeCombo_SelectionChanged"
                          DisplayMemberPath="Display"/>
                <TextBlock x:Name="TypeHintText"
                           Grid.Column="1"
                           Margin="10,0,0,0"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           MaxWidth="220"
                           TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <!-- ── TYPE_OBJECT — динамический блок ───────────────────────────── -->
        <GroupBox Header="{DynamicResource S.QTD.TypeObject}" Grid.Row="1">
            <StackPanel x:Name="TypeObjectPanel"/>
        </GroupBox>

        <!-- ── Прочие поля ────────────────────────────────────────────────── -->
        <GroupBox Header="{DynamicResource S.QTD.Params}" Grid.Row="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/><RowDefinition/><RowDefinition/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource S.F.Count}"/>
                <TextBox x:Name="CountBox" Grid.Row="0" Grid.Column="1" Text="1"/>

                <Label Grid.Row="0" Grid.Column="2" Content="{DynamicResource S.F.NeedLiquid}"/>
                <TextBox x:Name="NeedLiquidBox" Grid.Row="0" Grid.Column="3" Text="-1"/>

                <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource S.F.GeneralSettings}"/>
                <TextBox x:Name="SettingsBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                         ToolTip="Зависит от типа. Тип 9: радиус|уровень земли|на карте. Тип 10: пресет|-|закопан. Тип 12: triggerId|на карте. Тип 13: triggerId|mappingId|на карте"/>

                <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource S.F.NameOverride}"/>
                <TextBox x:Name="NameOverrideBox" Grid.Row="2" Grid.Column="1"/>

                <Label Grid.Row="2" Grid.Column="2" Content="{DynamicResource S.F.Image}"/>
                <TextBox x:Name="ImageOverrideBox" Grid.Row="2" Grid.Column="3"/>
            </Grid>
        </GroupBox>

        <!-- ── Описание SETTINGS ─────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,4">
            <StackPanel>
                <TextBlock Text="{DynamicResource S.QTD.Hint}"
                           Foreground="{DynamicResource AccentBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="SettingsHintText"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Text="{DynamicResource S.QTD.HintDefault}"/>
            </StackPanel>
        </Border>

        <!-- ── Кнопки ────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource S.Btn.Cancel}" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="{DynamicResource S.Btn.Save2}" Width="100"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
