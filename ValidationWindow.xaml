<Window x:Class="GMCraftTableEditor.ValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Validation.Title}"
        Height="620" Width="980"
        MinHeight="400" MinWidth="700"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource TextBrush}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="SummaryText"
                           FontSize="14" FontWeight="Bold"/>
                <TextBlock x:Name="SubText"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="12" Margin="0,3,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{DynamicResource S.Validation.Recheck}"
                    Style="{StaticResource AccentButton}"
                    Click="ReCheck_Click"/>
        </Grid>

        <!-- Фильтры -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource S.Validation.Show}" VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,8,0"/>
            <CheckBox x:Name="ShowErrors"   Content="{DynamicResource S.Validation.Errors}"       IsChecked="True"
                      Checked="Filter_Changed" Unchecked="Filter_Changed" Margin="0,0,12,0"/>
            <CheckBox x:Name="ShowWarnings" Content="{DynamicResource S.Validation.Warnings}" IsChecked="True"
                      Checked="Filter_Changed" Unchecked="Filter_Changed" Margin="0,0,12,0"/>
            <CheckBox x:Name="ShowInfo"     Content="{DynamicResource S.Validation.Info}"           IsChecked="True"
                      Checked="Filter_Changed" Unchecked="Filter_Changed" Margin="0,0,16,0"/>
            <Separator Width="1" Background="{DynamicResource BorderBrushSoft}" Margin="0,0,12,0"/>
            <TextBlock Text="{DynamicResource S.Validation.Section}" VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,8,0"/>
            <ComboBox x:Name="SectionFilter" Width="160"
                      SelectionChanged="Filter_Changed"/>
        </WrapPanel>

        <!-- Таблица результатов -->
        <DataGrid x:Name="ResultsGrid" Grid.Row="2"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  RowHeaderWidth="0"
                  ColumnHeaderHeight="32"
                  MouseDoubleClick="ResultsGrid_DoubleClick"
                  PreviewMouseRightButtonUp="ResultsGrid_RightClick"
                  Background="{DynamicResource PanelBackground}"
                  Foreground="{DynamicResource TextBrush}"
                  BorderBrush="{DynamicResource BorderBrushSoft}"
                  RowBackground="{DynamicResource PanelBackground}"
                  AlternatingRowBackground="{DynamicResource PanelBackground2}"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrushSoft}"
                  VerticalGridLinesBrush="Transparent"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                            <Setter Property="Background" Value="#3A1A1A"/>
                            <Setter Property="Foreground" Value="#FF8080"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                            <Setter Property="Background" Value="#2E2A14"/>
                            <Setter Property="Foreground" Value="#F0C040"/>
                        </DataTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource S.Validation.ColType}"      Binding="{Binding SeverityIcon}" Width="40"  IsReadOnly="True"/>
                <DataGridTextColumn Header="{DynamicResource S.Validation.ColSect}"   Binding="{Binding Section}"      Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="{DynamicResource S.Validation.ColObj}"   Binding="{Binding ObjectName}"   Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="{DynamicResource S.Validation.ColField}"     Binding="{Binding Field}"        Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="{DynamicResource S.Validation.ColProblem}" Binding="{Binding Message}"      Width="*"   IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CountText"
                       Foreground="{DynamicResource MutedTextBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="{DynamicResource S.Validation.GoTo}"
                    Style="{StaticResource AccentButton}"
                    Click="Navigate_Click" Margin="0,0,8,0"
                    ToolTip="Двойной клик по строке"/>
            <Button Grid.Column="2" Content="{DynamicResource S.Validation.Export}"
                    Click="Export_Click"/>
        </Grid>
    </Grid>
</Window>
