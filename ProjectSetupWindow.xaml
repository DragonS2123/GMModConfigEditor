<Window x:Class="GMCraftTableEditor.ProjectSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Setup.Title}"
        Width="540" Height="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource TextBrush}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="⚙" FontSize="22" Margin="0,0,10,0"
                       Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Text="{DynamicResource S.Setup.Title}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"/>
        </StackPanel>

        <!-- Описание -->
        <TextBlock Grid.Row="2"
                   Text="{DynamicResource S.Setup.Description}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource MutedTextBrush}"
                   FontSize="13"/>

        <!-- Поле пути -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="PathBox"
                     Grid.Column="0"
                     FontSize="13"
                     Padding="6,4"
                     Background="{DynamicResource InputBackground}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrushSoft}"
                     BorderThickness="1"/>

            <Button Grid.Column="2"
                    Content="{DynamicResource S.Setup.SelectFolder}"
                    Click="Browse_Click"
                    Padding="12,6"
                    Background="{DynamicResource PanelBackground2}"
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrushSoft}"
                    Cursor="Hand"/>
        </Grid>

        <!-- Статус -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="6"
                   Foreground="{DynamicResource DangerBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource S.Setup.Skip}"
                    Click="Skip_Click"
                    Padding="14,7"
                    Margin="0,0,8,0"
                    Background="{DynamicResource PanelBackground2}"
                    Foreground="{DynamicResource MutedTextBrush}"
                    BorderBrush="{DynamicResource BorderBrushSoft}"
                    Cursor="Hand"/>

            <Button x:Name="ContinueBtn"
                    Content="{DynamicResource S.Setup.Continue}"
                    Click="Continue_Click"
                    Padding="14,7"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
