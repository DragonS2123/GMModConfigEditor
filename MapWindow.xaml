<Window x:Class="GMCraftTableEditor.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="GM Mod Config Editor — Карта"
        Height="780" Width="1280"
        MinHeight="500" MinWidth="800"
        Background="#1a1a1a"
        Foreground="#e0e0e0"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Background="#1e1e1e" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="10,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Выбор карты -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Карта:" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="#888" FontSize="12"/>
                    <ComboBox x:Name="MapCombo" Width="180" FontSize="12"
                              SelectionChanged="MapCombo_Changed"/>
                    <Button Content="+ Своя карта" Margin="8,0,0,0" Padding="8,4"
                            Click="AddCustomMap_Click" FontSize="11"/>
                </StackPanel>

                <!-- Маркеры -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkNPC"      Content="🧑 NPC"      IsChecked="True" Margin="0,0,12,0"
                              Checked="Markers_Changed" Unchecked="Markers_Changed"/>
                    <CheckBox x:Name="ChkTriggers" Content="📍 Триггеры" IsChecked="True" Margin="0,0,12,0"
                              Checked="Markers_Changed" Unchecked="Markers_Changed"/>
                    <CheckBox x:Name="ChkRocks"    Content="⛏ Камни"    IsChecked="True"
                              Checked="Markers_Changed" Unchecked="Markers_Changed"/>
                </StackPanel>

                <!-- Перейти к позиции -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="X:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#888"/>
                    <TextBox x:Name="GotoX" Width="75" Margin="0,0,6,0" Padding="4,3" FontFamily="Consolas"/>
                    <TextBlock Text="Z:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#888"/>
                    <TextBox x:Name="GotoZ" Width="75" Margin="0,0,8,0" Padding="4,3" FontFamily="Consolas"/>
                    <Button Content="Перейти" Padding="8,4" Click="GotoPos_Click"/>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Button Content="🔄 Обновить" Padding="8,4" Click="RefreshMarkers_Click"/>
                </StackPanel>

                <!-- Координаты мыши -->
                <TextBlock x:Name="CoordText" Grid.Column="5"
                           VerticalAlignment="Center"
                           Foreground="#7ec8e3"
                           FontFamily="Consolas" FontSize="12"
                           Text="Наведи на карту..."/>
            </Grid>
        </Border>

        <!-- Карта -->
        <wv2:WebView2 x:Name="MapView" Grid.Row="1"/>
    </Grid>
</Window>
