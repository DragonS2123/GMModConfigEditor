<Window x:Class="GMCraftTableEditor.GlobalSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Глобальный поиск"
        Height="560" Width="860"
        MinHeight="400" MinWidth="600"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource TextBrush}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Строка поиска -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     FontSize="14"
                     Padding="10,8"
                     TextChanged="SearchBox_TextChanged"
                     KeyDown="SearchBox_KeyDown"
                     ToolTip="Поиск по classname, ключам, значениям (Ctrl+F для открытия)"/>
            <Button Grid.Column="1" Content="🔍 Найти" Width="100" Margin="8,0,0,0"
                    Click="DoSearch_Click" Style="{StaticResource AccentButton}"/>
            <Button Grid.Column="2" Content="✕ Очистить" Width="90" Margin="6,0,0,0"
                    Click="Clear_Click"/>
        </Grid>

        <!-- Фильтры -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Искать в:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource MutedTextBrush}"/>
            <CheckBox x:Name="ChkRecipes"  Content="Рецепты"      IsChecked="True" Margin="0,0,12,0"/>
            <CheckBox x:Name="ChkItems"    Content="Справочник"    IsChecked="True" Margin="0,0,12,0"/>
            <CheckBox x:Name="ChkQuests"   Content="Квесты"        IsChecked="True" Margin="0,0,12,0"/>
            <CheckBox x:Name="ChkNPC"      Content="NPC"           IsChecked="True" Margin="0,0,12,0"/>
            <CheckBox x:Name="ChkLoot"     Content="Пресеты лута"  IsChecked="True" Margin="0,0,12,0"/>
            <CheckBox x:Name="ChkMods"     Content="Моды (медицина/еда/майнинг)" IsChecked="True"/>
        </WrapPanel>

        <!-- Результаты -->
        <DataGrid x:Name="ResultsGrid" Grid.Row="2"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="ResultsGrid_DoubleClick"
                  PreviewMouseRightButtonUp="ResultsGrid_RightClick"
                  Background="{DynamicResource PanelBackground}"
                  Foreground="{DynamicResource TextBrush}"
                  RowBackground="{DynamicResource PanelBackground}"
                  AlternatingRowBackground="{DynamicResource PanelBackground2}"
                  BorderBrush="{DynamicResource BorderBrushSoft}"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrushSoft}"
                  VerticalGridLinesBrush="Transparent"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Раздел"    Binding="{Binding Section}"   Width="140"/>
                <DataGridTextColumn Header="Поле"      Binding="{Binding Field}"     Width="200"/>
                <DataGridTextColumn Header="Значение"  Binding="{Binding Value}"     Width="*"/>
                <DataGridTextColumn Header="Файл"      Binding="{Binding FileName}"  Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       Text="Введите запрос и нажмите Enter или кнопку Найти"
                       Foreground="{DynamicResource MutedTextBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Перейти →" Width="100"
                    Style="{StaticResource AccentButton}"
                    Click="Navigate_Click"
                    ToolTip="Двойной клик по строке или эта кнопка"/>
        </Grid>
    </Grid>
</Window>
