                                            <StackPanel><Label Content="EXTRACT_MIN_QUANTITY"/><TextBox x:Name="Mine_ExtMin" TextChanged="MineField_Changed" Tag="EXTRACTION_MINIMUM_QUANTITY"/></StackPanel>
                                            <StackPanel><Label Content="EXTRACT_MAX_QUANTITY"/><TextBox x:Name="Mine_ExtMax" TextChanged="MineField_Changed" Tag="EXTRACTION_MAXIMUM_QUANTITY"/></StackPanel>
                                            <StackPanel><Label Content="ROCK_BASE_MIN"/><TextBox x:Name="Mine_RockMin" TextChanged="MineField_Changed" Tag="ROCK_BASE_MIN_QUANTITY"/></StackPanel>
                                            <StackPanel><Label Content="ROCK_BASE_MAX"/><TextBox x:Name="Mine_RockMax" TextChanged="MineField_Changed" Tag="ROCK_BASE_MAX_QUANTITY"/></StackPanel>
                                        </UniformGrid>
                                    </GroupBox>
                                    <GroupBox Header="Blacksmith бонусы (ABILITY)">
                                        <UniformGrid Columns="4">
                                            <StackPanel><Label Content="CHANCE LVL0"/><TextBox x:Name="Mine_BC0" TextChanged="MineField_Changed" Tag="BLACKSMITH_CHANCE_BONUS_LEVEL0"/></StackPanel>
                                            <StackPanel><Label Content="CHANCE LVL1"/><TextBox x:Name="Mine_BC1" TextChanged="MineField_Changed" Tag="BLACKSMITH_CHANCE_BONUS_LEVEL1"/></StackPanel>
                                            <StackPanel><Label Content="CHANCE LVL2"/><TextBox x:Name="Mine_BC2" TextChanged="MineField_Changed" Tag="BLACKSMITH_CHANCE_BONUS_LEVEL2"/></StackPanel>
                                            <StackPanel><Label Content="CHANCE LVL3"/><TextBox x:Name="Mine_BC3" TextChanged="MineField_Changed" Tag="BLACKSMITH_CHANCE_BONUS_LEVEL3"/></StackPanel>
                                            <StackPanel><Label Content="QTY LVL0"/><TextBox x:Name="Mine_BQ0" TextChanged="MineField_Changed" Tag="BLACKSMITH_QUANTITY_BONUS_LEVEL0"/></StackPanel>
                                            <StackPanel><Label Content="QTY LVL1"/><TextBox x:Name="Mine_BQ1" TextChanged="MineField_Changed" Tag="BLACKSMITH_QUANTITY_BONUS_LEVEL1"/></StackPanel>
                                            <StackPanel><Label Content="QTY LVL2"/><TextBox x:Name="Mine_BQ2" TextChanged="MineField_Changed" Tag="BLACKSMITH_QUANTITY_BONUS_LEVEL2"/></StackPanel>
                                            <StackPanel><Label Content="QTY LVL3"/><TextBox x:Name="Mine_BQ3" TextChanged="MineField_Changed" Tag="BLACKSMITH_QUANTITY_BONUS_LEVEL3"/></StackPanel>
                                        </UniformGrid>
                                    </GroupBox>
                                    <GroupBox Header="DIG_SETTINGS — Копка">
                                        <UniformGrid Columns="3">
                                            <StackPanel><Label Content="CHANCE_OF_DIG"/><TextBox x:Name="Mine_DigChance" TextChanged="MineField_Changed" Tag="CHANCE_OF_DIG"/></StackPanel>
                                            <StackPanel><Label Content="CHANCE_OF_DIG_SAND"/><TextBox x:Name="Mine_DigSand" TextChanged="MineField_Changed" Tag="CHANCE_OF_DIG_SAND"/></StackPanel>
                                            <StackPanel><Label Content="DIG_DAMAGE_TOOLS"/><TextBox x:Name="Mine_DigDmg" TextChanged="MineField_Changed" Tag="DIG_DAMAGE_TO_TOOLS"/></StackPanel>
                                        </UniformGrid>
                                    </GroupBox>
                                    <GroupBox Header="WASH_SETTINGS — Промывка">
                                        <UniformGrid Columns="3">
                                            <StackPanel><Label Content="CHANCE_FOR_WASH"/><TextBox x:Name="Mine_WashChance" TextChanged="MineField_Changed" Tag="CHANCE_FOR_WASH"/></StackPanel>
                                            <StackPanel><Label Content="WASHED_MIN_QUANTITY"/><TextBox x:Name="Mine_WashMin" TextChanged="MineField_Changed" Tag="WASHED_MINIMUM_QUANTITY"/></StackPanel>
                                            <StackPanel><Label Content="WASHED_MAX_QUANTITY"/><TextBox x:Name="Mine_WashMax" TextChanged="MineField_Changed" Tag="WASHED_MAXIMUM_QUANTITY"/></StackPanel>
                                        </UniformGrid>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="EXTRACTION_ARRAY — Руды">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <ComboBox x:Name="MineExtCombo" Width="280"
                                              IsEditable="True" IsTextSearchEnabled="False"
                                              StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                              PreviewKeyUp="MineExtCombo_PreviewKeyUp"/>
                                    <Button Content="+ Добавить" Background="{DynamicResource AccentBrush}" Width="95" Click="AddMineExtItem_Click"/>
                                    <Button Content="Удалить" Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteMineExtItem_Click"/>
                                </StackPanel>
                                <ListBox x:Name="MineExtList" PreviewMouseRightButtonUp="ListBox_RightClick" Grid.Row="1"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                            </Grid>
                        </TabItem>
                        <TabItem Header="WASH_ARRAY — Промывка">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <ComboBox x:Name="MineWashCombo" Width="280"
                                              IsEditable="True" IsTextSearchEnabled="False"
                                              StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                              PreviewKeyUp="MineWashCombo_PreviewKeyUp"/>
                                    <Button Content="+ Добавить" Background="{DynamicResource AccentBrush}" Width="95" Click="AddMineWashItem_Click"/>
                                    <Button Content="Удалить" Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteMineWashItem_Click"/>
                                </StackPanel>
                                <ListBox x:Name="MineWashList" PreviewMouseRightButtonUp="ListBox_RightClick" Grid.Row="1"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                            </Grid>
                        </TabItem>
                        <TabItem Header="RECIPES — Плавка">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="+ Рецепт" Background="{DynamicResource AccentBrush}" Width="95" Click="AddMineRecipe_Click"/>
                                        <Button Content="Удалить"  Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteMineRecipe_Click"/>
                                    </StackPanel>
                                    <ListBox x:Name="MineRecipesList" Grid.Row="1"
                                             Background="{DynamicResource InputBackground}"
                                             Foreground="{DynamicResource TextBrush}"
                                             BorderBrush="{DynamicResource BorderBrushSoft}"
                                             DisplayMemberPath="RECIPE_NAME"
                                             SelectionChanged="MineRecipesList_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Grid>
                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="MineRecipeDetail" Margin="10,0,0,0" IsEnabled="False">
                                        <GroupBox Header="Основное">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/><ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="180"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <Label Content="RECIPE_NAME"/>
                                                <TextBox x:Name="MR_Name" Grid.Column="1" Grid.ColumnSpan="3" TextChanged="MineRecipeField_Changed" Tag="RECIPE_NAME"/>
                                                <Label Grid.Row="1" Content="RESULT"/>
                                                <ComboBox x:Name="MR_Result" Grid.Row="1" Grid.Column="1"
                                                          IsEditable="True" IsTextSearchEnabled="False"
                                                          StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                          PreviewKeyUp="MR_Result_PreviewKeyUp"
                                                          SelectionChanged="MR_Result_SelectionChanged"/>
                                                <Label Grid.Row="1" Grid.Column="2" Content="RESULT_QUANTITY"/>
                                                <TextBox x:Name="MR_ResultQty" Grid.Row="1" Grid.Column="3" TextChanged="MineRecipeField_Changed" Tag="RESULT_QUANTITY"/>
                                                <Label Grid.Row="2" Content="SPECIAL_INGREDIENTS"/>
                                                <ComboBox x:Name="MR_Special" Grid.Row="2" Grid.Column="1"
                                                          IsEditable="True" IsTextSearchEnabled="False"
                                                          StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                          PreviewKeyUp="MR_Special_PreviewKeyUp"
                                                          SelectionChanged="MR_Special_SelectionChanged"/>
                                                <Label Grid.Row="2" Grid.Column="2" Content="DAMAGE_TO_INGREDIENT"/>
                                                <TextBox x:Name="MR_DmgIng" Grid.Row="2" Grid.Column="3" TextChanged="MineRecipeField_Changed" Tag="DAMAGE_TO_INGREDIENT"/>
                                            </Grid>
                                        </GroupBox>
                                        <GroupBox Header="Флаги">
                                            <UniformGrid Columns="2">
                                                <StackPanel><Label Content="DELETE_SPECIAL_INGREDIENTS (0/1)"/><TextBox x:Name="MR_DelSpecial" TextChanged="MineRecipeField_Changed" Tag="DELETE_SPECIAL_INGREDIENTS"/></StackPanel>
                                                <StackPanel><Label Content="DAMAGE_SPECIAL_INGREDIENTS (0/1)"/><TextBox x:Name="MR_DmgSpecial" TextChanged="MineRecipeField_Changed" Tag="DAMAGE_SPECIAL_INGREDIENTS"/></StackPanel>
                                            </UniformGrid>
                                        </GroupBox>
                                        <GroupBox Header="INGREDIENTS — Ингредиенты">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="120"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <ComboBox x:Name="MR_IngCombo" Width="220"
                                                              IsEditable="True" IsTextSearchEnabled="False"
                                                              StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                              PreviewKeyUp="MR_IngCombo_PreviewKeyUp"/>
                                                    <TextBox x:Name="MR_IngQty" Width="60" Margin="4,0" ToolTip="Количество"/>
                                                    <Button Content="+ Добавить" Background="{DynamicResource AccentBrush}" Width="90" Click="AddMineIngredient_Click"/>
                                                    <Button Content="Удалить" Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteMineIngredient_Click"/>
                                                </StackPanel>
                                                <DataGrid x:Name="MineIngredientsGrid" Grid.Row="1" PreviewMouseRightButtonUp="DataGrid_RightClick">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="INGREDIENT" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                                        <DataGridTextColumn Header="QUANTITY"   Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Grid>
                                        </GroupBox>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>

                <!-- ── Страница: Rock Points ──────────────────────────── -->
                <Grid x:Name="Page_RockPoints" Visibility="Collapsed" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="+ Тип камня" Background="{DynamicResource AccentBrush}" Width="110" Click="AddRockObject_Click"/>
                            <Button Content="Удалить" Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteRockObject_Click"/>
                        </StackPanel>
                        <ListBox x:Name="RockObjectsList" Grid.Row="1"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrushSoft}"
                                 DisplayMemberPath="CLASSNAME"
                                 SelectionChanged="RockObjectsList_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                    </Grid>
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="RockObjectDetail" Margin="10,0,0,0" IsEnabled="False">
                            <GroupBox Header="Настройки объекта">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/><ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/><ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Label Content="CLASSNAME"/>
                                    <ComboBox x:Name="RO_Class" Grid.Column="1" Grid.ColumnSpan="3"
                                              IsEditable="True" IsTextSearchEnabled="False"
                                              StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                              PreviewKeyUp="RO_Class_PreviewKeyUp"
                                              SelectionChanged="RO_Class_SelectionChanged"/>
                                    <Label Grid.Row="1" Content="MIN_OBJECTS_ON_MAP"/>
                                    <TextBox x:Name="RO_Min" Grid.Row="1" Grid.Column="1" TextChanged="RockField_Changed" Tag="MIN_OBJECTS_ON_MAP"/>
                                    <Label Grid.Row="1" Grid.Column="2" Content="MAX_OBJECTS_ON_MAP"/>
                                    <TextBox x:Name="RO_Max" Grid.Row="1" Grid.Column="3" TextChanged="RockField_Changed" Tag="MAX_OBJECTS_ON_MAP"/>
                                    <Label Grid.Row="2" Content="RESPAWN_TIME (сек)"/>
                                    <TextBox x:Name="RO_Respawn" Grid.Row="2" Grid.Column="1" TextChanged="RockField_Changed" Tag="RESPAWN_TIME"/>
                                    <Label Grid.Row="2" Grid.Column="2" Content="SPAWN_CHANCE (%)"/>
                                    <TextBox x:Name="RO_SpawnChance" Grid.Row="2" Grid.Column="3" TextChanged="RockField_Changed" Tag="SPAWN_CHANCE"/>
                                    <Label Grid.Row="3" Content="MIN_EXTRACTION_AMOUNT"/>
                                    <TextBox x:Name="RO_ExtMin" Grid.Row="3" Grid.Column="1" TextChanged="RockField_Changed" Tag="MIN_EXTRACTION_AMOUNT"/>
                                    <Label Grid.Row="3" Grid.Column="2" Content="MAX_EXTRACTION_AMOUNT"/>
                                    <TextBox x:Name="RO_ExtMax" Grid.Row="3" Grid.Column="3" TextChanged="RockField_Changed" Tag="MAX_EXTRACTION_AMOUNT"/>
                                </Grid>
                            </GroupBox>
                            <GroupBox Header="POSITION — Позиции спавна (X Y Z)">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="150"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBox x:Name="RO_PosX" Width="80" Margin="0,0,4,0"/>
                                        <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBox x:Name="RO_PosY" Width="80" Margin="0,0,4,0"/>
                                        <TextBlock Text="Z" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBox x:Name="RO_PosZ" Width="80" Margin="0,0,6,0"/>
                                        <Button Content="+ Добавить" Background="{DynamicResource AccentBrush}" Width="90" Click="AddRockPos_Click"/>
                                        <Button Content="Удалить" Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteRockPos_Click"/>
                                    </StackPanel>
                                    <ListBox x:Name="RockPosList" Grid.Row="1"
                                             Background="{DynamicResource InputBackground}"
                                             Foreground="{DynamicResource TextBrush}"
                                             BorderBrush="{DynamicResource BorderBrushSoft}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── Страница: Карта ──────────────────────────────────── -->
                <Grid x:Name="Page_Map" Visibility="Collapsed" Margin="14">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🗺" FontSize="64" HorizontalAlignment="Center"
                                   Margin="0,0,0,20" Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock Text="Интерактивная карта DayZ"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Показывает позиции NPC, камней и триггеров на карте dayz.xam.nu"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Поддерживает 20+ карт: Chernarus, Livonia, Sakhal, Banov, DeerIsle и другие"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,30"/>
                        <Button Content="🗺  Открыть карту"
                                Style="{StaticResource AccentButton}"
                                Width="200" Padding="16,10" FontSize="15"
                                Click="OpenMapBtn_Click"
                                HorizontalAlignment="Center"/>
                        <TextBlock Margin="0,16,0,0" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                   Text="Требуется Microsoft Edge WebView2 Runtime (обычно уже установлен в Windows 10/11)"/>
                    </StackPanel>
                </Grid>

            </Grid>

            <!-- Статус-бар -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderBrushSoft}"
                    BorderThickness="0,1,0,0"
                    Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Статус -->
                    <TextBlock x:Name="StatusText" Text="Готово"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12" VerticalAlignment="Center"/>

                    <!-- Индикатор несохранённых изменений -->
                    <TextBlock x:Name="DirtyIndicator"
                               Grid.Column="1"
                               Text="● Несохранённые изменения"
                               Foreground="#F0C040"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Opacity="0"
                               ToolTip="Ctrl+S — сохранить всё"/>

                    <!-- Кнопка поиска -->
                    <Button Grid.Column="2"
                            Content="🔍 Ctrl+F"
                            Padding="8,3"
                            FontSize="11"
                            Margin="0,0,6,0"
                            Click="GlobalSearch_Click"
                            ToolTip="Глобальный поиск (Ctrl+F)"/>

                    <!-- Кнопка валидации -->
                    <Button Grid.Column="3"
                            Content="✓ Проверить"
                            Padding="8,3"
                            FontSize="11"
                            Click="Validate_Click"
                            ToolTip="Проверить все конфиги на ошибки (Ctrl+E)"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
