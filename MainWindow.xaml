<Window x:Class="GMCraftTableEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.App.Title}"
        Height="860" Width="1450"
        MinHeight="720" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource TextBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Боковое меню -->
            <ColumnDefinition Width="220"/>
            <!-- Контент -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             БОКОВОЕ МЕНЮ
        ══════════════════════════════════════════════════════════════════ -->
        <Border Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Логотип -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="0,0,0,1"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource S.App.Title}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="v1.5.0"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,2,0,0"/>
                        <!-- Язык и путь к проекту — под названием -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="📁"
                                    ToolTip="{DynamicResource S.Settings.ProjectPath}"
                                    Click="ProjectSettings_Click"
                                    Padding="4,3"
                                    FontSize="12"
                                    Background="{DynamicResource PanelBackground2}"
                                    Foreground="{DynamicResource MutedTextBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    Cursor="Hand"/>
                            <Button Grid.Column="2"
                                    x:Name="LangBtn"
                                    Content="{DynamicResource S.Lang.Button}"
                                    Click="LangBtn_Click"
                                    Width="36" Height="24"
                                    FontSize="11" FontWeight="Bold"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Переключатель темы внизу -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource S.Theme.Label}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{DynamicResource MutedTextBrush}"/>
                        <ComboBox x:Name="ThemeCombo" Grid.Column="1" Width="100"
                                  SelectionChanged="ThemeCombo_SelectionChanged">
                            <ComboBoxItem Content="{DynamicResource S.Theme.Dark}" IsSelected="True"/>
                            <ComboBoxItem Content="{DynamicResource S.Theme.Light}"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Навигация -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                        <!-- Секция: Крафт -->
                        <TextBlock Text="{DynamicResource S.Nav.Craft}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,8,0,4"/>

                        <Border x:Name="Nav_Recipes"
                                Style="{StaticResource NavItem}"
                                Tag="Recipes"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⚙" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.Recipes}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_GmConfig"
                                Style="{StaticResource NavItem}"
                                Tag="GmConfig"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔧" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.GmConfig}"/>
                            </StackPanel>
                        </Border>

                        <!-- Секция: Квест система -->
                        <TextBlock Text="{DynamicResource S.Nav.Quest}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,16,0,4"/>

                        <Border x:Name="Nav_Quests"
                                Style="{StaticResource NavItem}"
                                Tag="Quests"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📋" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.Quests}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_NPC"
                                Style="{StaticResource NavItem}"
                                Tag="{DynamicResource S.Nav.NPC}"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.NPC}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Loot"
                                Style="{StaticResource NavItem}"
                                Tag="Loot"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🎁" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.Loot}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Triggers"
                                Style="{StaticResource NavItem}"
                                Tag="Triggers"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📍" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.Triggers}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Player"
                                Style="{StaticResource NavItem}"
                                Tag="Player"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📊" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.Player}"/>
                            </StackPanel>
                        </Border>

                        <!-- Секция: Медицина -->
                        <TextBlock Text="{DynamicResource S.Nav.Medicine}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,16,0,4"/>

                        <Border x:Name="Nav_Medicine"
                                Style="{StaticResource NavItem}" Tag="Medicine"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="💊" FontSize="15" Margin="0,0,10,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.MedicineConfig}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Ability"
                                Style="{StaticResource NavItem}" Tag="Ability"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⭐" FontSize="15" Margin="0,0,10,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.AbilityConfig}"/>
                            </StackPanel>
                        </Border>

                        <!-- Секция: Еда -->
                        <TextBlock Text="{DynamicResource S.Nav.Food}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,16,0,4"/>

                        <Border x:Name="Nav_Liquid"
                                Style="{StaticResource NavItem}" Tag="Liquid"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🧪" FontSize="15" Margin="0,0,10,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.LiquidConfig}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Food"
                                Style="{StaticResource NavItem}" Tag="Food"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🍖" FontSize="15" Margin="0,0,10,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.FoodConfig}"/>
                            </StackPanel>
                        </Border>

                        <!-- Секция: Майнинг -->
                        <TextBlock Text="{DynamicResource S.Nav.Mining}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,16,0,4"/>

                        <Border x:Name="Nav_MineRock"
                                Style="{StaticResource NavItem}" Tag="MineRock"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⛏" FontSize="15" Margin="0,0,10,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.MineRock}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_RockPoints"
                                Style="{StaticResource NavItem}" Tag="RockPoints"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🪨" FontSize="15" Margin="0,0,10,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.RockPoints}"/>
                            </StackPanel>
                        </Border>

                        <!-- Секция: Настройки -->
                        <TextBlock Text="{DynamicResource S.Nav.Settings}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,16,0,4"/>

                        <Border x:Name="Nav_Map"
                                Style="{StaticResource NavItem}" Tag="Map"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🗺" FontSize="15" Margin="0,0,10,0" Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Nav.Map}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Items"
                                Style="{StaticResource NavItem}"
                                Tag="Items"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📦" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="{DynamicResource S.Items.Title}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             ПРАВАЯ ЧАСТЬ: топбар + контент
        ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Топбар -->
            <Border Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок страницы -->
                    <TextBlock x:Name="PageTitle"
                               Text="{DynamicResource S.Nav.Recipes}"
                               FontSize="15" FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <!-- Динамические кнопки — прокручиваемые если много кнопок -->
                    <ScrollViewer Grid.Column="2"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="TopbarActions"
                                    Orientation="Horizontal"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Контент страниц -->
            <Grid Grid.Row="1">

                <!-- ── Страница: Рецепты ──────────────────────────────── -->
                <Grid x:Name="Page_Recipes" Margin="8" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Grid.Column="0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                <TextBox x:Name="RecipeSearchBox"
                                         TextChanged="RecipeSearchBox_TextChanged"
                                         ToolTip="Поиск по названию, категории или результату"/>
                            </StackPanel>
                            <ListBox x:Name="RecipesList" PreviewMouseRightButtonUp="ListBox_RightClick"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrushSoft}"
                                     DisplayMemberPath="RECIPE_NAME"
                                     SelectionChanged="RecipesList_SelectionChanged"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedItem, ElementName=RecipesList}"
                                    Margin="4,0,0,0">
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource S.Recipe.BasicInfo}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="{DynamicResource S.F.RecipeName}"/>
                                        <TextBox Text="{Binding RECIPE_NAME, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{DynamicResource S.F.Description}" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding DESCRIPTION, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="50"/>
                                        <TextBlock Text="{DynamicResource S.F.Category}" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding CATEGORY, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{DynamicResource S.F.Result}" Margin="0,4,0,0"/>
                                        <ComboBox x:Name="ResultComboBox"
                                                  IsEditable="True" IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                  Text="{Binding RESULT, UpdateSourceTrigger=PropertyChanged}"
                                                  PreviewKeyUp="ResultComboBox_PreviewKeyUp"
                                                  SelectionChanged="ResultComboBox_SelectionChanged"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource S.Recipe.ResultTime}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="{DynamicResource S.F.ResultCount}"/>
                                        <TextBox Text="{Binding RESULT_COUNT, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{DynamicResource S.F.ResultHealth}" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding RESULT_HEALTH, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{DynamicResource S.F.TimeToCreate}" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding TIME_TO_CREATE, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{DynamicResource S.F.GivePoints}" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding GIVE_POINTS, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource S.Recipe.Blueprint}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="{DynamicResource S.F.Plan}"/>
                                        <ComboBox x:Name="PlanComboBox"
                                                  IsEditable="True" IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                  Text="{Binding PLAN, UpdateSourceTrigger=PropertyChanged}"
                                                  PreviewKeyUp="PlanComboBox_PreviewKeyUp"
                                                  SelectionChanged="PlanComboBox_SelectionChanged"/>
                                        <TextBlock Text="{DynamicResource S.F.DamageToPlan}" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding DAMAGE_TO_PLAN, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{DynamicResource S.F.Ability}" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding ABILITY, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{DynamicResource S.F.RequiredLevel}" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding REQUIRED_LEVEL, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <UniformGrid Columns="2">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource S.Recipe.Flags}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.WeaponRepair}"/><TextBox Text="{Binding WEAPON_REPAIR, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.OtherRepair}"/><TextBox Text="{Binding OTHER_REPAIR, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.Dismantle}"/><TextBox Text="{Binding DISMANTLE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.RemoteCraft}"/><TextBox Text="{Binding REMOTE_CRAFT, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.NeedElectricity}"/><TextBox Text="{Binding NEED_ELECTRICITY, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.NeedSpecialItems}"/><TextBox Text="{Binding NEED_SPECIAL_ITEMS, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource S.Recipe.Params}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.NeedCountKit}"/><TextBox Text="{Binding NEED_COUNT_KIT, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.ResultLiquid}"/><TextBox Text="{Binding RESULT_LIQUID, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.LiquidType}"/><TextBox Text="{Binding LIQUID_TYPE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.MinConsumption}"/><TextBox Text="{Binding MIN_CONSUMPTION, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.MaxConsumption}"/><TextBox Text="{Binding MAX_CONSUMPTION, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource S.Recipe.Tools}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ComboBox x:Name="ToolAutoCompleteBox" Width="150"
                                                      IsEditable="True" IsTextSearchEnabled="False"
                                                      StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                      PreviewKeyUp="ToolAutoCompleteBox_PreviewKeyUp"/>
                                            <Button Content="+" Click="AddTool_Click"/>
                                            <Button Content="✕" Style="{StaticResource DangerButton}" Click="DeleteTool_Click"/>
                                        </StackPanel>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.MinToolsDmg}"/><TextBox Text="{Binding MIN_TOOLS_DAMAGE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.MaxToolsDmg}"/><TextBox Text="{Binding MAX_TOOLS_DAMAGE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        </UniformGrid>
                                        <ListBox x:Name="ToolsList" PreviewMouseRightButtonUp="ListBox_RightClick" Height="110" ItemsSource="{Binding TOOLS}"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource S.Recipe.Kits}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ComboBox x:Name="KitItemCombo" Width="150"
                                                      IsEditable="True" IsTextSearchEnabled="False"
                                                      StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                      PreviewKeyUp="KitItemCombo_PreviewKeyUp"/>
                                            <Button Content="+" Click="AddKitItem_Click"/>
                                            <Button Content="✕" Style="{StaticResource DangerButton}" Click="DeleteKitItem_Click"/>
                                        </StackPanel>
                                        <ListBox x:Name="KitItemsList" PreviewMouseRightButtonUp="ListBox_RightClick" Height="165" ItemsSource="{Binding NEEDS_KIT_ITEMS}"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource S.Recipe.Special}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ComboBox x:Name="SpecialItemCombo" Width="150"
                                                      IsEditable="True" IsTextSearchEnabled="False"
                                                      StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                      PreviewKeyUp="SpecialItemCombo_PreviewKeyUp"/>
                                            <Button Content="+" Click="AddSpecialItem_Click"/>
                                            <Button Content="✕" Style="{StaticResource DangerButton}" Click="DeleteSpecialItem_Click"/>
                                        </StackPanel>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.MinAttachDmg}"/><TextBox Text="{Binding MIN_ATTACHMENT_DAMAGE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="{DynamicResource S.F.MaxAttachDmg}"/><TextBox Text="{Binding MAX_ATTACHMENT_DAMAGE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        </UniformGrid>
                                        <ListBox x:Name="SpecialItemsList" PreviewMouseRightButtonUp="ListBox_RightClick" Height="90" ItemsSource="{Binding NEEDS_SPECIAL_ITEMS}"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource S.Recipe.Ingredients}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <ComboBox x:Name="IngredientAutoCompleteBox" Width="280"
                                                  IsEditable="True" IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                  PreviewKeyUp="IngredientAutoCompleteBox_PreviewKeyUp"/>
                                        <Button Content="{DynamicResource S.Recipe.AddIngr}" Click="AddIngredientFromAutoComplete_Click" Margin="8,0,0,0"/>
                                        <Button Content="{DynamicResource S.Btn.Delete}" Style="{StaticResource DangerButton}" Click="DeleteIngredient_Click" Margin="4,0,0,0"/>
                                        <Button Content="{DynamicResource S.Btn.CheckRecipes}" Click="ValidateRecipes_Click" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <DataGrid x:Name="IngredientsGrid" PreviewMouseRightButtonUp="DataGrid_RightClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="{DynamicResource S.F.ClassName}"      Binding="{Binding CLASSNAME,                  UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="{DynamicResource S.Col.Count}"         Binding="{Binding ITEM_AMOUNT,                UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="{DynamicResource S.Col.Energy}"        Binding="{Binding USE_ENERGY,                 UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="{DynamicResource S.Col.LiquidType}"       Binding="{Binding NEED_LIQUID,                UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="{DynamicResource S.Col.LiquidType}"   Binding="{Binding LIQUID_TYPE,                UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                            <DataGridTextColumn Header="{DynamicResource S.Btn.Destroy}"     Binding="{Binding DESTROY_ITEM,               UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                            <DataGridTextColumn Header="{DynamicResource S.Col.Damage}"  Binding="{Binding CHANGE_HEALTH_ITEM_BY_CRAFT,UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── Страница: Справочник предметов ────────────────── -->
                <Grid x:Name="Page_Items" Margin="10" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="{DynamicResource S.Recipe.ToResult}"  Click="UseAsResult_Click"/>
