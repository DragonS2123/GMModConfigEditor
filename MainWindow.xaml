<Window x:Class="GMCraftTableEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GM Mod Config Editor"
        Height="860" Width="1450"
        MinHeight="720" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource TextBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Боковое меню -->
            <ColumnDefinition Width="220"/>
            <!-- Контент -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             БОКОВОЕ МЕНЮ
        ══════════════════════════════════════════════════════════════════ -->
        <Border Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Логотип -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="0,0,0,1"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="GM Mod Config Editor"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="v1.1.0"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Переключатель темы внизу -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Тема" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{DynamicResource MutedTextBrush}"/>
                        <ComboBox x:Name="ThemeCombo" Grid.Column="1" Width="100"
                                  SelectionChanged="ThemeCombo_SelectionChanged">
                            <ComboBoxItem Content="🌙 Тёмная" IsSelected="True"/>
                            <ComboBoxItem Content="☀ Светлая"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Навигация -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                        <!-- Секция: Крафт -->
                        <TextBlock Text="КРАФТ"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,8,0,4"/>

                        <Border x:Name="Nav_Recipes"
                                Style="{StaticResource NavItem}"
                                Tag="Recipes"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⚙" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="Рецепты"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Items"
                                Style="{StaticResource NavItem}"
                                Tag="Items"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📦" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="Справочник предметов"/>
                            </StackPanel>
                        </Border>

                        <!-- Секция: Квест система -->
                        <TextBlock Text="КВЕСТ СИСТЕМА"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,16,0,4"/>

                        <Border x:Name="Nav_Quests"
                                Style="{StaticResource NavItem}"
                                Tag="Quests"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📋" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="Квесты"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_NPC"
                                Style="{StaticResource NavItem}"
                                Tag="NPC"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="NPC"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Loot"
                                Style="{StaticResource NavItem}"
                                Tag="Loot"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🎁" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="Пресеты лута"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Triggers"
                                Style="{StaticResource NavItem}"
                                Tag="Triggers"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📍" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="Триггеры / Маппинг"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="Nav_Player"
                                Style="{StaticResource NavItem}"
                                Tag="Player"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📊" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="Прогресс игрока"/>
                            </StackPanel>
                        </Border>

                        <!-- Секция: Настройки -->
                        <TextBlock Text="НАСТРОЙКИ"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="16,16,0,4"/>

                        <Border x:Name="Nav_GmConfig"
                                Style="{StaticResource NavItem}"
                                Tag="GmConfig"
                                MouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔧" FontSize="15" Margin="0,0,10,0"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock Text="GM Config"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             ПРАВАЯ ЧАСТЬ: топбар + контент
        ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Топбар -->
            <Border Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок страницы -->
                    <TextBlock x:Name="PageTitle"
                               Text="Рецепты"
                               FontSize="15" FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <!-- Динамические кнопки -->
                    <StackPanel x:Name="TopbarActions"
                                Grid.Column="2"
                                Orientation="Horizontal"/>
                </Grid>
            </Border>

            <!-- Контент страниц -->
            <Grid Grid.Row="1">

                <!-- ── Страница: Рецепты ──────────────────────────────── -->
                <Grid x:Name="Page_Recipes" Margin="8" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Grid.Column="0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                <TextBox x:Name="RecipeSearchBox"
                                         TextChanged="RecipeSearchBox_TextChanged"
                                         ToolTip="Поиск по названию, категории или результату"/>
                            </StackPanel>
                            <ListBox x:Name="RecipesList"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrushSoft}"
                                     DisplayMemberPath="RECIPE_NAME"
                                     SelectionChanged="RecipesList_SelectionChanged"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedItem, ElementName=RecipesList}"
                                    Margin="4,0,0,0">
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Основная информация" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="RECIPE_NAME"/>
                                        <TextBox Text="{Binding RECIPE_NAME, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="DESCRIPTION" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding DESCRIPTION, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="50"/>
                                        <TextBlock Text="CATEGORY" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding CATEGORY, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="RESULT" Margin="0,4,0,0"/>
                                        <ComboBox x:Name="ResultComboBox"
                                                  IsEditable="True" IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                  Text="{Binding RESULT, UpdateSourceTrigger=PropertyChanged}"
                                                  PreviewKeyUp="ResultComboBox_PreviewKeyUp"
                                                  SelectionChanged="ResultComboBox_SelectionChanged"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Результат и время" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="RESULT_COUNT"/>
                                        <TextBox Text="{Binding RESULT_COUNT, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="RESULT_HEALTH" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding RESULT_HEALTH, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="TIME_TO_CREATE" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding TIME_TO_CREATE, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="GIVE_POINTS" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding GIVE_POINTS, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Чертёж и навык" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="PLAN"/>
                                        <ComboBox x:Name="PlanComboBox"
                                                  IsEditable="True" IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                  Text="{Binding PLAN, UpdateSourceTrigger=PropertyChanged}"
                                                  PreviewKeyUp="PlanComboBox_PreviewKeyUp"
                                                  SelectionChanged="PlanComboBox_SelectionChanged"/>
                                        <TextBlock Text="DAMAGE_TO_PLAN" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding DAMAGE_TO_PLAN, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="ABILITY" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding ABILITY, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="REQUIRED_LEVEL" Margin="0,4,0,0"/>
                                        <TextBox Text="{Binding REQUIRED_LEVEL, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <UniformGrid Columns="2">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Флаги (0/1)" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="WEAPON_REPAIR"/><TextBox Text="{Binding WEAPON_REPAIR, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="OTHER_REPAIR"/><TextBox Text="{Binding OTHER_REPAIR, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="DISMANTLE"/><TextBox Text="{Binding DISMANTLE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="REMOTE_CRAFT"/><TextBox Text="{Binding REMOTE_CRAFT, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="NEED_ELECTRICITY"/><TextBox Text="{Binding NEED_ELECTRICITY, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="NEED_SPECIAL_ITEMS"/><TextBox Text="{Binding NEED_SPECIAL_ITEMS, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Параметры" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="NEED_COUNT_KIT"/><TextBox Text="{Binding NEED_COUNT_KIT, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="RESULT_LIQUID"/><TextBox Text="{Binding RESULT_LIQUID, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="LIQUID_TYPE"/><TextBox Text="{Binding LIQUID_TYPE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="MIN_CONSUMPTION"/><TextBox Text="{Binding MIN_CONSUMPTION, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="MAX_CONSUMPTION"/><TextBox Text="{Binding MAX_CONSUMPTION, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Инструменты TOOLS" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ComboBox x:Name="ToolAutoCompleteBox" Width="150"
                                                      IsEditable="True" IsTextSearchEnabled="False"
                                                      StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                      PreviewKeyUp="ToolAutoCompleteBox_PreviewKeyUp"/>
                                            <Button Content="+" Click="AddTool_Click"/>
                                            <Button Content="✕" Style="{StaticResource DangerButton}" Click="DeleteTool_Click"/>
                                        </StackPanel>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="MIN_TOOLS_DMG"/><TextBox Text="{Binding MIN_TOOLS_DAMAGE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="MAX_TOOLS_DMG"/><TextBox Text="{Binding MAX_TOOLS_DAMAGE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        </UniformGrid>
                                        <ListBox x:Name="ToolsList" Height="110" ItemsSource="{Binding TOOLS}"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Наборы NEEDS_KIT_ITEMS" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBox x:Name="KitItemText" Width="150"/>
                                            <Button Content="+" Click="AddKitItem_Click"/>
                                            <Button Content="✕" Style="{StaticResource DangerButton}" Click="DeleteKitItem_Click"/>
                                        </StackPanel>
                                        <ListBox x:Name="KitItemsList" Height="165" ItemsSource="{Binding NEEDS_KIT_ITEMS}"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Спец. предметы" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBox x:Name="SpecialItemText" Width="150"/>
                                            <Button Content="+" Click="AddSpecialItem_Click"/>
                                            <Button Content="✕" Style="{StaticResource DangerButton}" Click="DeleteSpecialItem_Click"/>
                                        </StackPanel>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="MIN_ATTACH_DMG"/><TextBox Text="{Binding MIN_ATTACHMENT_DAMAGE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                            <StackPanel><TextBlock Text="MAX_ATTACH_DMG"/><TextBox Text="{Binding MAX_ATTACHMENT_DAMAGE, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        </UniformGrid>
                                        <ListBox x:Name="SpecialItemsList" Height="90" ItemsSource="{Binding NEEDS_SPECIAL_ITEMS}"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Ингредиенты INGRIDIENTS" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <ComboBox x:Name="IngredientAutoCompleteBox" Width="280"
                                                  IsEditable="True" IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True" DisplayMemberPath="ClassName"
                                                  PreviewKeyUp="IngredientAutoCompleteBox_PreviewKeyUp"/>
                                        <Button Content="+ Ингредиент" Click="AddIngredientFromAutoComplete_Click" Margin="8,0,0,0"/>
                                        <Button Content="Удалить" Style="{StaticResource DangerButton}" Click="DeleteIngredient_Click" Margin="4,0,0,0"/>
                                        <Button Content="Проверить рецепты" Click="ValidateRecipes_Click" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <DataGrid x:Name="IngredientsGrid">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="CLASSNAME"      Binding="{Binding CLASSNAME,                  UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="Кол-во"         Binding="{Binding ITEM_AMOUNT,                UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="Энергия"        Binding="{Binding USE_ENERGY,                 UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="Жидкость"       Binding="{Binding NEED_LIQUID,                UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="Тип жидкости"   Binding="{Binding LIQUID_TYPE,                UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                            <DataGridTextColumn Header="Уничтожить"     Binding="{Binding DESTROY_ITEM,               UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                            <DataGridTextColumn Header="Урон здоровью"  Binding="{Binding CHANGE_HEALTH_ITEM_BY_CRAFT,UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── Страница: Справочник предметов ────────────────── -->
                <Grid x:Name="Page_Items" Margin="10" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="+ Добавить"         Click="AddItemDb_Click"/>
                        <Button Content="Удалить"            Style="{StaticResource DangerButton}" Click="DeleteItemDb_Click"/>
                        <Button Content="Импорт TXT"         Click="ImportItemsTxt_Click"/>
                        <Button Content="Импорт types.xml"   Click="ImportTypesXml_Click"/>
                        <Button Content="Импорт папки types" Click="ImportTypesFolder_Click"/>
                        <Button Content="Сохранить"          Click="SaveItemDb_Click"/>
                        <Separator Width="1" Background="{DynamicResource BorderBrushSoft}" Margin="6,0"/>
                        <Button Content="→ В результат"  Click="UseAsResult_Click"/>
                        <Button Content="→ В чертёж"     Click="UseAsPlan_Click"/>
                        <Button Content="→ В инструмент" Click="UseAsTool_Click"/>
                        <Button Content="→ В ингредиент" Click="UseAsIngredient_Click"/>
                        <Separator Width="1" Background="{DynamicResource BorderBrushSoft}" Margin="6,0"/>
                        <Button Content="Проверить рецепты" Click="ValidateRecipes_Click"/>
                        <TextBox x:Name="ItemDbSearchBox" Width="240" Margin="8,0,0,0"
                                 TextChanged="ItemDbSearchBox_TextChanged"
                                 ToolTip="Поиск по ClassName, названию, категории или моду"/>
                    </WrapPanel>
                    <DataGrid x:Name="ItemsGrid" Grid.Row="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ClassName"   Binding="{Binding ClassName,   UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridTextColumn Header="Название"    Binding="{Binding DisplayName,  UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridTextColumn Header="Категория"   Binding="{Binding Category,     UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="Мод"         Binding="{Binding SourceMod,    UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment,      UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridCheckBoxColumn Header="★"       Binding="{Binding Favorite,     UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- ── Заглушки для Quest System страниц (открываются в QuestSystemWindow) -->
                <Grid x:Name="Page_Quests" Visibility="Collapsed">
<Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="+ Квест"    Background="{DynamicResource AccentBrush}" Width="90" Click="AddQuest_Click"/>
                            <Button Content="Удалить"    Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteQuest_Click"/>
                            <Button Content="Копировать" Width="90" Click="DuplicateQuest_Click"/>
                        </StackPanel>
                        <ListBox x:Name="QuestsList"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrushSoft}" Grid.Row="1"
                                 DisplayMemberPath="QUEST_NAME"
                                 SelectionChanged="QuestsList_SelectionChanged"/>
                    </Grid>
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="QuestDetailPanel" Margin="10,0,0,0" IsEnabled="False">

                            <GroupBox Header="Основное">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Label Grid.Row="0" Grid.Column="0" Content="QUEST_NAME"/>
                                    <TextBox x:Name="QN_Name" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" TextChanged="QuestField_Changed" Tag="QUEST_NAME"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="DESCRIPTION_SHORT"/>
                                    <TextBox x:Name="QN_DescShort" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" TextChanged="QuestField_Changed" Tag="DESCRIPTION_SHORT"/>
                                    <Label Grid.Row="2" Grid.Column="0" Content="GLOBAL_TYPE (1-14)"/>
                                    <TextBox x:Name="QN_GlobalType" Grid.Row="2" Grid.Column="1" TextChanged="QuestField_Changed" Tag="GLOBAL_TYPE"/>
                                    <Label Grid.Row="2" Grid.Column="2" Content="RELOAD_QUEST"/>
                                    <TextBox x:Name="QN_Reload" Grid.Row="2" Grid.Column="3" TextChanged="QuestField_Changed" Tag="RELOAD_QUEST"/>
                                    <Label Grid.Row="3" Grid.Column="0" Content="TIME_LIMIT"/>
                                    <TextBox x:Name="QN_TimeLimit" Grid.Row="3" Grid.Column="1" TextChanged="QuestField_Changed" Tag="TIME_LIMIT_FOR_QUEST"/>
                                    <Label Grid.Row="3" Grid.Column="2" Content="CAN_CANCEL"/>
                                    <TextBox x:Name="QN_CanCancel" Grid.Row="3" Grid.Column="3" TextChanged="QuestField_Changed" Tag="CAN_CANCEL_QUEST"/>
                                    <Label Grid.Row="4" Grid.Column="0" Content="QUEST_REQUIRED"/>
                                    <TextBox x:Name="QN_Required" Grid.Row="4" Grid.Column="1" TextChanged="QuestField_Changed" Tag="QUEST_REQUIRED"/>
                                    <Label Grid.Row="4" Grid.Column="2" Content="UNAVAILABLE"/>
                                    <TextBox x:Name="QN_Unavailable" Grid.Row="4" Grid.Column="3" TextChanged="QuestField_Changed" Tag="QUEST_UNAVAILABLE"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="DESCRIPTION (полное)">
                                <TextBox x:Name="QN_Desc" Height="70" TextWrapping="Wrap"
                                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                         TextChanged="QuestField_Changed" Tag="DESCRIPTION"/>
                            </GroupBox>

                            <GroupBox Header="Репутация / Расписание">
                                <UniformGrid Columns="4">
                                    <StackPanel><Label Content="REP_REWARD"/><TextBox x:Name="QN_RepReward"  TextChanged="QuestField_Changed" Tag="REPUTATION_REWARD"/></StackPanel>
                                    <StackPanel><Label Content="REP_PENALTY"/><TextBox x:Name="QN_RepPenalty" TextChanged="QuestField_Changed" Tag="REPUTATION_PENALTY"/></StackPanel>
                                    <StackPanel><Label Content="NEED_REP"/><TextBox x:Name="QN_NeedRep"    TextChanged="QuestField_Changed" Tag="NEED_REPUTATION"/></StackPanel>
                                    <StackPanel><Label Content="UNIQUE (0/1)"/><TextBox x:Name="QN_Unique"     TextChanged="QuestField_Changed" Tag="UNIQUE"/></StackPanel>
                                    <StackPanel><Label Content="HOUR_START"/><TextBox x:Name="QN_HStart"    TextChanged="QuestField_Changed" Tag="HOUR_START"/></StackPanel>
                                    <StackPanel><Label Content="MIN_START"/><TextBox x:Name="QN_MStart"    TextChanged="QuestField_Changed" Tag="MINUTE_START"/></StackPanel>
                                    <StackPanel><Label Content="HOUR_FINISH"/><TextBox x:Name="QN_HFinish"   TextChanged="QuestField_Changed" Tag="HOUR_FINISH"/></StackPanel>
                                    <StackPanel><Label Content="MIN_FINISH"/><TextBox x:Name="QN_MFinish"   TextChanged="QuestField_Changed" Tag="MINUTE_FINISH"/></StackPanel>
                                </UniformGrid>
                            </GroupBox>

                            <GroupBox Header="DAY_QUEST">
                                <WrapPanel x:Name="DayQuestPanel">
                                    <CheckBox Content="Monday"    Tag="Monday"    Checked="DayQuest_Changed" Unchecked="DayQuest_Changed"/>
                                    <CheckBox Content="Tuesday"   Tag="Tuesday"   Checked="DayQuest_Changed" Unchecked="DayQuest_Changed"/>
                                    <CheckBox Content="Wednesday" Tag="Wednesday" Checked="DayQuest_Changed" Unchecked="DayQuest_Changed"/>
                                    <CheckBox Content="Thursday"  Tag="Thursday"  Checked="DayQuest_Changed" Unchecked="DayQuest_Changed"/>
                                    <CheckBox Content="Friday"    Tag="Friday"    Checked="DayQuest_Changed" Unchecked="DayQuest_Changed"/>
                                    <CheckBox Content="Saturday"  Tag="Saturday"  Checked="DayQuest_Changed" Unchecked="DayQuest_Changed"/>
                                    <CheckBox Content="Sunday"    Tag="Sunday"    Checked="DayQuest_Changed" Unchecked="DayQuest_Changed"/>
                                </WrapPanel>
                            </GroupBox>

                            <GroupBox Header="TARGETS — Цели">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="160"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="+ Цель"        Background="{DynamicResource AccentBrush}" Width="80" Click="AddTarget_Click"/>
                                        <Button Content="Редактировать" Width="110" Click="EditTarget_Click"/>
                                        <Button Content="Удалить"       Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteTarget_Click"/>
                                        <TextBlock Text="  ✎ Двойной клик — открыть редактор"
                                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DataGrid x:Name="TargetsGrid" Grid.Row="1" MouseDoubleClick="TargetsGrid_MouseDoubleClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Тип (1-14)"  Binding="{Binding TYPE_QUEST}" Width="80"/>
                                            <DataGridTextColumn Header="TYPE_OBJECT" Binding="{Binding TYPE_OBJECT}" Width="*"/>
                                            <DataGridTextColumn Header="Название"    Binding="{Binding TYPE_NAME_OVERRIDE}" Width="130"/>
                                            <DataGridTextColumn Header="Описание"    Binding="{Binding DESCRIPTION}" Width="130"/>
                                            <DataGridTextColumn Header="COUNT"       Binding="{Binding COUNT}" Width="60"/>
                                            <DataGridTextColumn Header="NEED_LIQ"    Binding="{Binding NEED_LIQUID}" Width="80"/>
                                            <DataGridTextColumn Header="SETTINGS"    Binding="{Binding SETTINGS}" Width="150"/>
                                            <DataGridTextColumn Header="IMAGE"       Binding="{Binding IMAGE_OVERRIDE}" Width="150"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="REWARDS — Награды">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="130"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="+ Награда" Background="{DynamicResource AccentBrush}" Width="90" Click="AddReward_Click"/>
                                        <Button Content="Удалить"   Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteReward_Click"/>
                                    </StackPanel>
                                    <DataGrid x:Name="RewardsGrid" Grid.Row="1">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="TYPE_OBJECT"  Binding="{Binding TYPE_OBJECT, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="COUNT"        Binding="{Binding COUNT, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                            <DataGridTextColumn Header="QUANTITY"     Binding="{Binding QUANTITY, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="Название"     Binding="{Binding TYPE_NAME_OVERRIDE, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                            <DataGridTextColumn Header="Описание"     Binding="{Binding DESCRIPTION, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                            <DataGridTextColumn Header="SET_LIQUID"   Binding="{Binding SET_LIQUID, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                            <DataGridTextColumn Header="HEALTH"       Binding="{Binding HEALTH_LEVEL, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="SETTINGS"     Binding="{Binding SETTINGS, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="COST_QUEST — Стоимость получения">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="110"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="+ Предмет" Background="{DynamicResource AccentBrush}" Width="95" Click="AddCost_Click"/>
                                        <Button Content="Удалить"   Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteCost_Click"/>
                                    </StackPanel>
                                    <DataGrid x:Name="CostGrid" Grid.Row="1">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="TYPE_OBJECT"   Binding="{Binding TYPE_OBJECT, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="COUNT"         Binding="{Binding COUNT, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                            <DataGridTextColumn Header="NEED_LIQUID"   Binding="{Binding NEED_LIQUID, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                            <DataGridTextColumn Header="NAME_OVERRIDE" Binding="{Binding NAME_OVERRIDE, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                                            <DataGridTextColumn Header="SETTINGS"      Binding="{Binding SETTINGS, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                </Grid>
                <Grid x:Name="Page_NPC" Visibility="Collapsed">
<Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="+ NPC"      Background="{DynamicResource AccentBrush}" Width="80" Click="AddNpc_Click"/>
                            <Button Content="Удалить"    Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteNpc_Click"/>
                            <Button Content="Копировать" Width="90" Click="DuplicateNpc_Click"/>
                        </StackPanel>
                        <ListBox x:Name="NpcList"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrushSoft}" Grid.Row="1"
                                 DisplayMemberPath="NPC_NAME"
                                 SelectionChanged="NpcList_SelectionChanged"/>
                    </Grid>
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="NpcDetailPanel" Margin="10,0,0,0" IsEnabled="False">

                            <GroupBox Header="Основная информация">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Label Grid.Row="0" Grid.Column="0" Content="NPC_ID"/>
                                    <TextBox x:Name="NN_Id" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Opacity="0.6"/>
                                    <Label Grid.Row="0" Grid.Column="2" Content="NPC_TYPE"/>
                                    <TextBox x:Name="NN_Type" Grid.Row="0" Grid.Column="3" TextChanged="NpcField_Changed" Tag="NPC_TYPE"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="NPC_NAME"/>
                                    <TextBox x:Name="NN_Name" Grid.Row="1" Grid.Column="1" TextChanged="NpcField_Changed" Tag="NPC_NAME"/>
                                    <Label Grid.Row="1" Grid.Column="2" Content="NPC_NAME_FOR_ACTION"/>
                                    <TextBox x:Name="NN_NameAction" Grid.Row="1" Grid.Column="3" TextChanged="NpcField_Changed" Tag="NPC_NAME_FOR_ACTION"/>
                                    <Label Grid.Row="2" Grid.Column="0" Content="NPC_ROLE"/>
                                    <TextBox x:Name="NN_Role" Grid.Row="2" Grid.Column="1" TextChanged="NpcField_Changed" Tag="NPC_ROLE"/>
                                    <Label Grid.Row="2" Grid.Column="2" Content="ENABLE_TRANSFER (0/1)"/>
                                    <TextBox x:Name="NN_Transfer" Grid.Row="2" Grid.Column="3" TextChanged="NpcField_Changed" Tag="ENABLE_TRANSFER"/>
                                    <Label Grid.Row="3" Grid.Column="0" Content="POSITION"/>
                                    <TextBox x:Name="NN_Pos" Grid.Row="3" Grid.Column="1" TextChanged="NpcField_Changed" Tag="POSITION"/>
                                    <Label Grid.Row="3" Grid.Column="2" Content="ORIENTATION"/>
                                    <TextBox x:Name="NN_Orient" Grid.Row="3" Grid.Column="3" TextChanged="NpcField_Changed" Tag="ORIENTATION"/>
                                    <Label Grid.Row="4" Grid.Column="0" Content="NPC_AVATAR_PATH"/>
                                    <TextBox x:Name="NN_Avatar" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" TextChanged="NpcField_Changed" Tag="NPC_AVATAR_PATH"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="NPC_DESCRIPTION">
                                <TextBox x:Name="NN_Desc" Height="55" TextWrapping="Wrap"
                                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                         TextChanged="NpcField_Changed" Tag="NPC_DESCRIPTION"/>
                            </GroupBox>

                            <GroupBox Header="Квесты и репутация">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Label Grid.Row="0" Grid.Column="0" Content="QUEST_START (1|2|3)"/>
                                    <TextBox x:Name="NN_QStart" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" TextChanged="NpcField_Changed" Tag="QUEST_START"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="QUEST_FINISH (1|2|3)"/>
                                    <TextBox x:Name="NN_QFinish" Grid.Row="1" Grid.Column="1" TextChanged="NpcField_Changed" Tag="QUEST_FINISH"/>
                                    <Label Grid.Row="1" Grid.Column="2" Content="LOW_REP / HIGH_REP"/>
                                    <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal">
                                        <TextBox x:Name="NN_RepLow" Width="80" TextChanged="NpcField_Changed" Tag="REP_LOW"/>
                                        <TextBlock Text=" / " VerticalAlignment="Center" Margin="4,0"/>
                                        <TextBox x:Name="NN_RepHigh" Width="80" TextChanged="NpcField_Changed" Tag="REP_HIGH"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="ATTACHMENTS — Экипировка NPC">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="100"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="NpcAttachText" Width="280" Margin="0,0,6,0"/>
                                        <Button Content="+ Добавить" Width="90" Click="AddNpcAttach_Click"/>
                                        <Button Content="Удалить" Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteNpcAttach_Click"/>
                                    </StackPanel>
                                    <ListBox x:Name="NpcAttachList" Grid.Row="1"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="DIALOG_SETTINGS — Диалоги">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="120"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="+ Диалог" Background="{DynamicResource AccentBrush}" Width="90" Click="AddNpcDialog_Click"/>
                                        <Button Content="Удалить"  Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteNpcDialog_Click"/>
                                        <TextBlock Text="  ID: first, quest, final, quit — зарезервированы"
                                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DataGrid x:Name="NpcDialogsGrid" Grid.Row="1"
                                              Background="{DynamicResource PanelBackground}"
                                              Foreground="{DynamicResource TextBrush}"
                                              RowBackground="{DynamicResource PanelBackground}"
                                              AlternatingRowBackground="{DynamicResource PanelBackground2}"
                                              BorderBrush="{DynamicResource BorderBrushSoft}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID"            Binding="{Binding ID, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                            <DataGridTextColumn Header="Текст (норм.)" Binding="{Binding NPC_TEXT_NORMAL, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="Текст (низк.)" Binding="{Binding NPC_TEXT_LOW_REPUTATION, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="Текст (выс.)"  Binding="{Binding NPC_TEXT_HIGH_REPUTATION, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="Ответов"       Binding="{Binding ANSWERS.Count}" Width="70"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                </Grid>
                <Grid x:Name="Page_Loot" Visibility="Collapsed">
<Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="+ Пресет"  Background="{DynamicResource AccentBrush}" Width="90" Click="AddLootPreset_Click"/>
                            <Button Content="Удалить"   Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteLootPreset_Click"/>
                        </StackPanel>
                        <ListBox x:Name="LootPresetsList"
                                 Background="{DynamicResource InputBackground}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrushSoft}" Grid.Row="1" SelectionChanged="LootPresetsList_SelectionChanged"/>
                    </Grid>
                    <Grid Grid.Column="1" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <GroupBox Header="STASH_POSITIONS — Позиции схронов">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="90"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBox x:Name="StashPosText" Width="230" Margin="0,0,6,0"/>
                                    <Button Content="Добавить" Width="80" Click="AddStashPos_Click"/>
                                    <Button Content="Удалить"  Width="80" Click="DeleteStashPos_Click"/>
                                </StackPanel>
                                <ListBox x:Name="StashPosList" Grid.Row="1"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrushSoft}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="ITEMS_LIST — Предметы в схроне" Grid.Row="1">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="+ Предмет" Background="{DynamicResource AccentBrush}" Width="95" Click="AddLootItem_Click"/>
                                <Button Content="Удалить"   Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteLootItem_Click"/>
                            </StackPanel>
                        </GroupBox>
                        <DataGrid x:Name="LootItemsGrid" Grid.Row="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CLASSNAME"    Binding="{Binding CLASSNAME, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="CHANCE (0-1)" Binding="{Binding CHANCE_TO_CREATE, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                <DataGridTextColumn Header="COUNT"        Binding="{Binding COUNT_ITEM, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                <DataGridTextColumn Header="HEALTH (0-1)" Binding="{Binding HEALTH_ITEM, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                <DataGridCheckBoxColumn Header="HAS_QTY"  Binding="{Binding HAS_QUANTITY, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                <DataGridTextColumn Header="QUANTITY"     Binding="{Binding QUANTITY_ITEM, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
                </Grid>
                <Grid x:Name="Page_Triggers" Visibility="Collapsed">
<Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <GroupBox Header="TRIGGER_SETTINGS — Зоны спавна зомби">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="+ Триггер" Background="{DynamicResource AccentBrush}" Width="95" Click="AddTrigger_Click"/>
                                <Button Content="Удалить"   Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteTrigger_Click"/>
                            </StackPanel>
                            <DataGrid x:Name="TriggersGrid" Grid.Row="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"          Binding="{Binding TRIGGER_ID}" Width="50"/>
                                    <DataGridTextColumn Header="Позиция"     Binding="{Binding POSITION, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                                    <DataGridTextColumn Header="Радиус"      Binding="{Binding RADIUS, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                    <DataGridTextColumn Header="Уведомление" Binding="{Binding NOTIFICATION_TEXT, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="Показ (сек)" Binding="{Binding TIME_SHOW_NOTIFICATION, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                    <DataGridTextColumn Header="Задержка"    Binding="{Binding DELAY_SPAWN, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                    <DataGridTextColumn Header="Кол-во AI"   Binding="{Binding AI_SETTINGS.COUNT_AI}" Width="80"/>
                                    <DataGridTextColumn Header="Радиус AI"   Binding="{Binding AI_SPAWN_RADIUS, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="MAPPING_SETTINGS — Группы маппинга" Grid.Row="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="+ Группа" Background="{DynamicResource AccentBrush}" Width="90" Click="AddMappingGroup_Click"/>
                                <Button Content="Удалить"  Background="{DynamicResource DangerBrush}" Width="80" Click="DeleteMappingGroup_Click"/>
                            </StackPanel>
                            <DataGrid x:Name="MappingGrid" Grid.Row="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="GROUP_ID"  Binding="{Binding GROUP_ID}" Width="80"/>
                                    <DataGridTextColumn Header="Название"  Binding="{Binding GROUP_NAME, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                                    <DataGridTextColumn Header="Объектов"  Binding="{Binding MAPPING_ITEMS.Count}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>
                </Grid>
                </Grid>
                <Grid x:Name="Page_Player" Visibility="Collapsed">
<Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Label Content="SteamID:"/>
                        <TextBlock x:Name="PlayerSteamIdText" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <Label Content="  Репутация:"/>
                        <TextBlock x:Name="PlayerReputationText" Foreground="#F0C040" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="Квесты в процессе:" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,4"/>
                    <DataGrid x:Name="InProgressGrid" Grid.Row="2" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"             Binding="{Binding ID}" Width="60"/>
                            <DataGridTextColumn Header="SYSTEM_ID"      Binding="{Binding SYSTEM_ID}" Width="120"/>
                            <DataGridTextColumn Header="IS_FINISH"      Binding="{Binding IS_FINISH}" Width="80"/>
                            <DataGridTextColumn Header="Прогресс целей" Binding="{Binding ProgressDisplay}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Выполненные квесты:" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,4"/>
                            <DataGrid x:Name="FinishedGrid" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"        Binding="{Binding ID}" Width="60"/>
                                    <DataGridTextColumn Header="SYSTEM_ID" Binding="{Binding SYSTEM_ID}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Проваленные квесты:" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,4"/>
                            <DataGrid x:Name="FailedGrid" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"        Binding="{Binding ID}" Width="60"/>
                                    <DataGridTextColumn Header="SYSTEM_ID" Binding="{Binding SYSTEM_ID}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>
                </Grid>
                </Grid>
                <Grid x:Name="Page_GmConfig" Visibility="Collapsed"><TextBlock Text="GM Config"         Style="{StaticResource PagePlaceholder}"/></Grid>

            </Grid>

            <!-- Статус-бар -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderBrushSoft}"
                    BorderThickness="0,1,0,0"
                    Padding="14,5">
                <TextBlock x:Name="StatusText" Text="Готово"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="12"/>
            </Border>
        </Grid>
    </Grid>
</Window>
