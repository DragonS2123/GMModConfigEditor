<Window x:Class="GMCraftTableEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GM Craft Table Editor" Height="860" Width="1450"
        MinHeight="720" MinWidth="1100" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#159A8C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C94545" />
        <SolidColorBrush x:Key="AppBackground" Color="#F4F6F8" />
        <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBackground2" Color="#EEF2F6" />
        <SolidColorBrush x:Key="TextBrush" Color="#151A20" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#59636F" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D0D7DF" />
        <SolidColorBrush x:Key="InputBackground" Color="#FFFFFF" />

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>

            <Style.Triggers>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PanelBackground2}"/>
                </Trigger>

            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>

            <Style.Triggers>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>

            </Style.Triggers>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="{DynamicResource PanelBackground2}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="7" />
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="4,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="4" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="RowBackground" Value="{DynamicResource PanelBackground}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource PanelBackground2}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="ColumnHeaderHeight" Value="30" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PanelBackground2}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="14"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">

                                <Grid>
                                    <ToggleButton x:Name="ToggleButton"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  ClickMode="Press"
                                                  Background="Transparent"
                                                  BorderThickness="0"/>

                                    <ContentPresenter Margin="8,0,30,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"/>

                                    <TextBox x:Name="PART_EditableTextBox"
                                             Margin="8,0,30,0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextBrush}"
                                             VerticalContentAlignment="Center"
                                             Visibility="Hidden"/>

                                    <TextBlock Text="▼"
                                               Foreground="{DynamicResource TextBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                </Grid>
                            </Border>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Focusable="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">

                                <Border Background="{DynamicResource PanelBackground2}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1">

                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>

                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground2}"/>
            <Setter Property="Padding" Value="6,4"/>

            <Style.Triggers>

                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>

            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Открыть крафт JSON" Click="OpenRecipes_Click" />
                    <Button Content="Сохранить крафт JSON" Click="SaveRecipes_Click" />
                    <TextBlock x:Name="StatusText" Margin="22,0,0,0" Text="Готово" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Тема:" Margin="0,0,6,0" />
                    <ComboBox x:Name="ThemeCombo" Width="130" SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="Тёмная" IsSelected="True" />
                        <ComboBoxItem Content="Светлая" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource BorderBrushSoft}">
            <TabItem Header="Крафт">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Card}" Grid.Column="0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <Button Content="GM CONFIG" Click="OpenGmConfigWindow_Click"/>
                                <Button Content="+ Добавить рецепт" Style="{StaticResource AccentButton}" Click="AddRecipe_Click" />
                                <Button Content="Удалить" Click="DeleteRecipe_Click" />
                                <TextBox x:Name="RecipeSearchBox" TextChanged="RecipeSearchBox_TextChanged" ToolTip="Поиск по названию, категории или результату" />
                            </StackPanel>
                            <ListBox x:Name="RecipesList" DisplayMemberPath="RECIPE_NAME" SelectionChanged="RecipesList_SelectionChanged" />
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedItem, ElementName=RecipesList}">
                            <TextBlock Text="Редактор рецепта" FontSize="22" FontWeight="Bold" Margin="8" />
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Основная информация" FontWeight="Bold" Margin="4" />
                                        <TextBlock Text="Название RECIPE_NAME" Margin="4"/><TextBox Text="{Binding RECIPE_NAME, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Описание DESCRIPTION" Margin="4"/><TextBox Text="{Binding DESCRIPTION, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="55" />
                                        <TextBlock Text="Категория CATEGORY" Margin="4"/><TextBox Text="{Binding CATEGORY, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Результат RESULT" Margin="4"/><ComboBox x:Name="ResultComboBox" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" DisplayMemberPath="ClassName" Text="{Binding RESULT, UpdateSourceTrigger=PropertyChanged}" PreviewKeyUp="ResultComboBox_PreviewKeyUp" SelectionChanged="ResultComboBox_SelectionChanged"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Результат и время" FontWeight="Bold" Margin="4" />
                                        <TextBlock Text="Кол-во результата RESULT_COUNT" Margin="4"/><TextBox Text="{Binding RESULT_COUNT, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Здоровье результата RESULT_HEALTH" Margin="4"/><TextBox Text="{Binding RESULT_HEALTH, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Время крафта TIME_TO_CREATE" Margin="4"/><TextBox Text="{Binding TIME_TO_CREATE, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Очки GIVE_POINTS" Margin="4"/><TextBox Text="{Binding GIVE_POINTS, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Чертёж и навык" FontWeight="Bold" Margin="4" />
                                        <TextBlock Text="Чертёж PLAN" Margin="4"/><ComboBox x:Name="PlanComboBox" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" DisplayMemberPath="ClassName" Text="{Binding PLAN, UpdateSourceTrigger=PropertyChanged}" PreviewKeyUp="PlanComboBox_PreviewKeyUp" SelectionChanged="PlanComboBox_SelectionChanged"/>
                                        <TextBlock Text="Урон чертежу DAMAGE_TO_PLAN" Margin="4"/><TextBox Text="{Binding DAMAGE_TO_PLAN, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Навык ABILITY" Margin="4"/><TextBox Text="{Binding ABILITY, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Требуемый уровень REQUIRED_LEVEL" Margin="4"/><TextBox Text="{Binding REQUIRED_LEVEL, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <UniformGrid Columns="2">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Режимы 0/1" FontWeight="Bold" Margin="4" />
                                        <TextBlock Text="WEAPON_REPAIR"/><TextBox Text="{Binding WEAPON_REPAIR, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="OTHER_REPAIR"/><TextBox Text="{Binding OTHER_REPAIR, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="DISMANTLE"/><TextBox Text="{Binding DISMANTLE, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="REMOTE_CRAFT"/><TextBox Text="{Binding REMOTE_CRAFT, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="NEED_ELECTRICITY"/><TextBox Text="{Binding NEED_ELECTRICITY, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="NEED_SPECIAL_ITEMS"/><TextBox Text="{Binding NEED_SPECIAL_ITEMS, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Дополнительно" FontWeight="Bold" Margin="4" />
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="NEED_COUNT_KIT"/><TextBox Text="{Binding NEED_COUNT_KIT, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                            <StackPanel><TextBlock Text="RESULT_LIQUID"/><TextBox Text="{Binding RESULT_LIQUID, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                            <StackPanel><TextBlock Text="LIQUID_TYPE"/><TextBox Text="{Binding LIQUID_TYPE, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                            <StackPanel><TextBlock Text="MIN_CONSUMPTION"/><TextBox Text="{Binding MIN_CONSUMPTION, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                            <StackPanel><TextBlock Text="MAX_CONSUMPTION"/><TextBox Text="{Binding MAX_CONSUMPTION, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Инструменты TOOLS" FontWeight="Bold" Margin="4" />
                                        <StackPanel Orientation="Horizontal"><ComboBox x:Name="ToolAutoCompleteBox" Width="260" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" DisplayMemberPath="ClassName" PreviewKeyUp="ToolAutoCompleteBox_PreviewKeyUp"/><Button Content="Добавить" Click="AddTool_Click"/><Button Content="Удалить" Click="DeleteTool_Click"/></StackPanel>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="MIN_TOOLS_DAMAGE"/><TextBox Text="{Binding MIN_TOOLS_DAMAGE, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                            <StackPanel><TextBlock Text="MAX_TOOLS_DAMAGE"/><TextBox Text="{Binding MAX_TOOLS_DAMAGE, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        </UniformGrid>
                                        <ListBox x:Name="ToolsList" Height="130" ItemsSource="{Binding TOOLS}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Наборы NEEDS_KIT_ITEMS" FontWeight="Bold" Margin="4" />
                                        <StackPanel Orientation="Horizontal"><TextBox x:Name="KitItemText" Width="210"/><Button Content="Добавить" Click="AddKitItem_Click"/><Button Content="Удалить" Click="DeleteKitItem_Click"/></StackPanel>
                                        <ListBox x:Name="KitItemsList" Height="185" ItemsSource="{Binding NEEDS_KIT_ITEMS}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Спец. предметы NEEDS_SPECIAL_ITEMS" FontWeight="Bold" Margin="4" />
                                        <StackPanel Orientation="Horizontal"><TextBox x:Name="SpecialItemText" Width="210"/><Button Content="Добавить" Click="AddSpecialItem_Click"/><Button Content="Удалить" Click="DeleteSpecialItem_Click"/></StackPanel>
                                        <UniformGrid Columns="2">
                                            <StackPanel><TextBlock Text="MIN_ATTACHMENT_DAMAGE"/><TextBox Text="{Binding MIN_ATTACHMENT_DAMAGE, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                            <StackPanel><TextBlock Text="MAX_ATTACHMENT_DAMAGE"/><TextBox Text="{Binding MAX_ATTACHMENT_DAMAGE, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        </UniformGrid>
                                        <ListBox x:Name="SpecialItemsList" Height="105" ItemsSource="{Binding NEEDS_SPECIAL_ITEMS}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Ингредиенты INGRIDIENTS" FontSize="16" FontWeight="Bold" Margin="4" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">

                                        <ComboBox x:Name="IngredientAutoCompleteBox"
                                                  Width="320"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True"
                                                  DisplayMemberPath="ClassName"
                                                  PreviewKeyUp="IngredientAutoCompleteBox_PreviewKeyUp"/>

                                        <Button Content="Добавить INGREDIENT"
                                                Click="AddIngredientFromAutoComplete_Click"
                                                Margin="8,0,0,0"/>
                                        <Button Content="Удалить ингредиент" 
                                                Click="DeleteIngredient_Click"
                                                Margin="8,0,0,0"/>
                                        <Button Content="Проверить рецепты" 
                                                Click="ValidateRecipes_Click"
                                                Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <DataGrid x:Name="IngredientsGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0"
                                              Background="{DynamicResource PanelBackground}"
                                              Foreground="{DynamicResource TextBrush}"
                                              BorderBrush="{DynamicResource BorderBrushSoft}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="CLASSNAME" Binding="{Binding CLASSNAME, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                            <DataGridTextColumn Header="Кол-во" Binding="{Binding ITEM_AMOUNT, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                            <DataGridTextColumn Header="Энергия" Binding="{Binding USE_ENERGY, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                            <DataGridTextColumn Header="Жидкость" Binding="{Binding NEED_LIQUID, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                            <DataGridTextColumn Header="Тип жидкости" Binding="{Binding LIQUID_TYPE, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                                            <DataGridTextColumn Header="Уничтожить" Binding="{Binding DESTROY_ITEM, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                            <DataGridTextColumn Header="Урон здоровью" Binding="{Binding CHANGE_HEALTH_ITEM_BY_CRAFT, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Справочник предметов">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
            
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button Content="Добавить" Click="AddItemDb_Click" Margin="0,0,8,0"/>
                        <Button Content="Удалить" Click="DeleteItemDb_Click" Margin="0,0,8,0"/>
                        <Button Content="Импорт TXT" Click="ImportItemsTxt_Click" Margin="0,0,8,0"/>
                        <Button Content="Импорт types.xml" Click="ImportTypesXml_Click" Margin="0,0,8,0"/>
                        <Button Content="Импорт папки types" Click="ImportTypesFolder_Click" Margin="0,0,8,0"/>
                        <Button Content="Сохранить справочник" Click="SaveItemDb_Click" Margin="0,0,8,0"/>
            
                        <Button Content="В результат" Click="UseAsResult_Click" Margin="12,0,8,0"/>
                        <Button Content="В чертёж" Click="UseAsPlan_Click" Margin="0,0,8,0"/>
                        <Button Content="В инструмент" Click="UseAsTool_Click" Margin="0,0,8,0"/>
                        <Button Content="В ингредиент" Click="UseAsIngredient_Click" Margin="0,0,8,0"/>
            
                        <TextBox x:Name="ItemDbSearchBox"
                                 Width="260"
                                 Margin="12,0,0,0"
                                 TextChanged="ItemDbSearchBox_TextChanged"
                                 ToolTip="Поиск по ClassName, названию, категории или моду"/>
                        
                        <Button Content="Проверить рецепты" Click="ValidateRecipes_Click" Margin="12,0,0,0"/>
                    </StackPanel>
            
                    <DataGrid x:Name="ItemsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ClassName" Binding="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="Мод" Binding="{Binding SourceMod, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridCheckBoxColumn Header="★" Binding="{Binding Favorite, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
