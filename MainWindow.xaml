                <!-- ── Страница: Medicine Config ──────────────────────── -->
                <Grid x:Name="Page_Medicine" Visibility="Collapsed" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBox x:Name="MedicineSearchBox" Width="240"
                                 TextChanged="MedicineSearchBox_TextChanged"
                                 ToolTip="Поиск по ключу"/>
